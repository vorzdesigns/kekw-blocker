{
  "manifest_version": 3,
  "name": "KEKW Blocker",
  "version": "1.2.0",
  "description": "Twitch ad blocker that fixes itself.",
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "scripting",
    "webRequest"
  ],
  "host_permissions": [
    "*://*.twitch.tv/*",
    "*://*.ttvnw.net/*",
    "*://*.jtvnw.net/*",
    "https://dorquex-ctrl.github.io/*"
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["src/config.js", "src/content/content-manager.js", "src/content/player-monitor.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/blank.ts", "src/content/page-inject.js"],
      "matches": ["*://*.twitch.tv/*"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "declarative_net_request": {
    "rule_resources": [{
      "id": "ruleset_1",
      "enabled": true,
      "path": "rules.json"
    }]
  }
}